keybind = global:cmd+g=toggle_quick_terminal

quick-terminal-position = top
quick-terminal-screen = mouse
quick-terminal-animation-duration = 0.2

background-opacity = 0.75
background = black

font-feature = -dlig
font-family  = "Monaco"
font-size    = 12

cursor-style = block
shell-integration-features = no-cursor

# 通常のタブのみ
window-padding-x = 20
